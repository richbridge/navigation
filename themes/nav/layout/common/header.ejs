<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge, chrome=1" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="theme-color" content="#f9f9f9" />
  <title><%= setting.tittle || config.title %> - <%= setting.subtitle || config.subtitle %></title>
  <meta name="keywords" content="<%= setting.keywords || config.keywords %>" />
  <meta name="description" content="<%= setting.description || config.description %>">
  <link rel="shortcut icon" href="<%= setting.cdn %><%= setting.favicon %>">
  <link rel="stylesheet" href="<%= setting.cdn %>css/bootstrap.min.css" type="text/css" media="all" />
  <link rel="stylesheet" href="<%= setting.cdn %>css/style.css"  type="text/css" media="all" />
  <link rel="stylesheet" href="<%= setting.cdn %>css/custom-style.css" type="text/css" media="all" />
  <link rel="stylesheet" href="<%= setting.cdn %>css/font-awesome.css">
  <script type="text/javascript" src="<%= setting.cdn %>js/jquery-3.6.0.min.js"></script>
  <style>
      body,html{font-size:15px;}
  </style>
   <% if (setting.custom && setting.custom.head) { %>
    <%- setting.custom.head %>
    <% } %>
</head>